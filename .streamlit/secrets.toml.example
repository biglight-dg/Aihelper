# 공유 비밀번호 설정 견본.
# 실제 값은 .streamlit/secrets.toml 에 넣으세요 (이 파일은 견본, secrets.toml 은 .gitignore 로 보호됨).
#
# - admin_password : 관리자(당신). 삭제·관리 포함 전체 기능.
# - guest_password : 지인 공유용. 보기 + 입력만(삭제·관리 버튼은 숨김).
# 둘 다 비워두면(또는 파일이 없으면) 게이트 없이 로컬에서 관리자로 통과합니다.

admin_password = "여기에-관리자-비밀번호"
guest_password = "여기에-손님-공유-비밀번호"
